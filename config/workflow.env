# Shared defaults for the Qwen3-8B acceleration homework.
# Override any value in the shell before running scripts, for example:
# MODEL_ID=Qwen/Qwen3-8B MAX_SAMPLES=5000 ./scripts/prepare_data.sh

MODEL_ID="${MODEL_ID:-Qwen/Qwen3-8B}"
DATASET="${DATASET:-sharegpt}"
BENCH_DATASET_PATH="${BENCH_DATASET_PATH:-philschmid/mt-bench}"
BENCH_DATASET_NAME="${BENCH_DATASET_NAME:-hf}"
MAX_SAMPLES="${MAX_SAMPLES:-3000}"
SEQ_LENGTH="${SEQ_LENGTH:-2048}"
BENCH_NUM_PROMPTS="${BENCH_NUM_PROMPTS:-80}"
BENCH_CONCURRENCY="${BENCH_CONCURRENCY:-8}"
SEED="${SEED:-42}"

ROOT_DIR="${ROOT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
SPECULATORS_REPO="${SPECULATORS_REPO:-${ROOT_DIR}/speculators}"
OUTPUT_DIR="${OUTPUT_DIR:-${ROOT_DIR}/output}"
PREPROCESSED_DIR="${PREPROCESSED_DIR:-${OUTPUT_DIR}/preprocessed}"
HIDDEN_STATES_DIR="${HIDDEN_STATES_DIR:-${OUTPUT_DIR}/hidden_states}"
CHECKPOINT_DIR="${CHECKPOINT_DIR:-${OUTPUT_DIR}/checkpoints}"
FP8_SPECULATOR_DIR="${FP8_SPECULATOR_DIR:-${OUTPUT_DIR}/checkpoints/checkpoint_best_fp8_verifier}"
LOG_DIR="${LOG_DIR:-${OUTPUT_DIR}/logs}"
MODEL_DIR="${MODEL_DIR:-${ROOT_DIR}/models}"
FP8_MODEL_DIR="${FP8_MODEL_DIR:-${MODEL_DIR}/Qwen3-8B-FP8-Dynamic}"
BENCH_DIR="${BENCH_DIR:-${OUTPUT_DIR}/benchmarks}"

VLLM_ENDPOINT="${VLLM_ENDPOINT:-http://localhost:8000/v1}"
VLLM_HOST="${VLLM_HOST:-0.0.0.0}"
VLLM_PORT="${VLLM_PORT:-8000}"
GPU_MEMORY_UTILIZATION="${GPU_MEMORY_UTILIZATION:-0.90}"
MAX_MODEL_LEN="${MAX_MODEL_LEN:-4096}"

DRAFT_VOCAB_SIZE="${DRAFT_VOCAB_SIZE:-32000}"
DRAFT_ARCH="${DRAFT_ARCH:-llama}"
EPOCHS="${EPOCHS:-5}"
LR="${LR:-1e-4}"
TOTAL_SEQ_LEN="${TOTAL_SEQ_LEN:-8192}"
HIDDEN_STATE_CONCURRENCY="${HIDDEN_STATE_CONCURRENCY:-32}"

SPEC_TOKENS="${SPEC_TOKENS:-2}"
FP8_SPEC_TOKENS="${FP8_SPEC_TOKENS:-1}"
